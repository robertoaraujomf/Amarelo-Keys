#!/bin/bash
# Pre-removal script for Amarelo Keys

set -e

echo "Removendo Amarelo Keys..."

# Remove autostart file if exists
if [ -n "$SUDO_USER" ]; then
    USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
    rm -f "$USER_HOME/.config/autostart/amarelo-keys.desktop" 2>/dev/null || true
fi

# Remove user config (optional - commented out to preserve user data)
# rm -rf "$HOME/.config/amarelo-keys" 2>/dev/null || true

echo "Amarelo Keys removido."
